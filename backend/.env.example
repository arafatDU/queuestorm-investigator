# QueueStorm Investigator - Environment Variables Example
# Copy this file to `.env` and fill in real values. Never commit `.env` to git.

# ----- Application -----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# ----- LLM Provider (Gemini / Gemma) -----
# API key for the Gemini API used by the LLMOrchestrator service.
# Required to enable LLM-generated text; if empty, the service falls back
# to deterministic templates.
GEMINI_API_KEY=
# Gemma 3 instruction-tuned model (27B). Adjust if you swap providers.
GEMINI_MODEL=gemma-3-27b-it
# Public Gemini REST base URL. Override only for staging / private endpoints.
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Per-call timeout for the Gemini API. Must be <30s to fit the analyze-ticket
# SLA enforced by the judge harness. The investigator + safety pipeline
# typically uses 1-2s, so 20s leaves headroom for slow networks.
LLM_TIMEOUT_SECONDS=20

# Sampling temperature for Gemini. Lower values keep replies grounded in
# the seeded facts. Range 0.0-2.0.
LLM_TEMPERATURE=0.2

# Maximum output tokens for the Gemini reply. The three fields we generate
# fit comfortably in 512 tokens; raise only if you switch to a longer prompt.
LLM_MAX_OUTPUT_TOKENS=512

# ----- Safety -----
# Toggle the post-LLM sanitizer that overwrites unsafe replies.
# Strongly recommended: keep TRUE. Disabling is only for debugging.
SAFETY_SANITIZER_ENABLED=true

# ----- Observability -----
SERVICE_NAME=queuestorm-investigator-backend